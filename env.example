# ==========================================
# CONFIGURAÇÕES DO CHAT AI (Assistente IA)
# ==========================================

# Escolha o provider: 'groq', 'openai', ou 'anthropic'
LLM_PROVIDER=groq

# GROQ (Recomendado - GRATUITO e RÁPIDO!)
# 1. Acesse: https://console.groq.com
# 2. Crie uma conta gratuita
# 3. Vá em "API Keys" e crie uma nova chave
# 4. Cole a chave abaixo
GROQ_API_KEY=

# OpenAI (Opcional - Pago)
# Obtenha sua chave em: https://platform.openai.com
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude (Opcional - Pago)
# Obtenha sua chave em: https://console.anthropic.com
# ANTHROPIC_API_KEY=

# ==========================================
# CIRCLE.SO (Comunidade - Opcional)
# ==========================================

# Circle.so API Configuration
# Substitua pelos seus valores reais
# VITE_CIRCLE_API_TOKEN=seu_token_aqui
# VITE_CIRCLE_COMMUNITY_ID=seu_community_id_aqui

# ==========================================
# BACKEND CONFIGURATION
# ==========================================

# Para desenvolvimento local:
VITE_API_URL=http://localhost:3000

# Para produção na Vercel, use a URL de produção:
# VITE_API_URL=https://areamembros-eta.vercel.app

VITE_USE_BACKEND=true

# Porta do servidor backend
PORT=3000
